{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(Changes detected|Compiling|Building)"
          },
          "endsPattern": {
            "regexp": "(bundle generation (complete|failed)|Compiled successfully|Local:http)"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(Changes detected|Compiling|Building)"
          },
          "endsPattern": {
            "regexp": "(bundle generation (complete|failed)|Compiled successfully)"
          }
        }
      }
    }
  ]
}